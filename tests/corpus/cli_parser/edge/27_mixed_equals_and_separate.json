{
  "description": "Mix equals-form and separate-value flags in the same argv.",
  "argv": [
    "ashyterm",
    "--ssh=u@h",
    "-w",
    "/tmp",
    "--close-after-execute"
  ],
  "expected": {
    "working_directory": "/tmp",
    "execute_command": null,
    "ssh_target": "u@h",
    "close_after_execute": true,
    "force_new_window": false
  }
}
