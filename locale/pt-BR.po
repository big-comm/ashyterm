msgid "Connection Refused"
msgstr "Conexão recusada"

#: /src/ashyterm/ui/ssh_dialogs.py:157
msgid ""
"The server refused the connection. Check if SSH is running on the server."
msgstr ""
"O servidor recusou a conexão. Verifique se o SSH está em execução no "
"servidor."

