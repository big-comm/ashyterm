msgid "SSH Agent Error"
msgstr "Erro do agente SSH"

#: /src/ashyterm/ui/ssh_dialogs.py:101
msgid ""
"SSH agent refused the operation. Check if your key is loaded with ssh-add."
msgstr ""
"O agente SSH recusou a operação. Verifique se sua chave está carregada com "
"ssh-add."

