#: /src/ashyterm/ui/ssh_dialogs.py:120 /src/ashyterm/ui/ssh_dialogs.py:127
msgid "Host Key Changed"
msgstr "A chave do host foi alterada"

#: /src/ashyterm/ui/ssh_dialogs.py:122
msgid ""
